@model IEnumerable<SistemaReservas.Models.Alojamientos>

@{
    ViewData["Title"] = "Alojamientos";
}

<div class="container mt-4">

    <section class="inventario-section">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Habitaciones / Alojamientos</h2>
            @if (User.IsInRole("Admin"))
            {
            <a asp-action="Create" class="btn about-team-card">
                + Registrar alojamiento
            </a>
            }
        </div>

        <div class="table-responsive">

            <table class="table-inventario">

                <thead>
                    <tr>
                        <th>Detalles</th>
                        <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                        <th>@Html.DisplayNameFor(model => model.Capacidad)</th>
                        <th>Tarifa Ordinaria</th>
                        <th>Tarifa Especial</th>
                        <th>Disponibilidad</th>
                        <th>Calendario</th>
                        <th>Reservar</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-xs">
                                    Ver
                                </a>
                            </td>

                            <td>
                                @Html.DisplayFor(model => item.Nombre)
                            </td>

                            <td>
                                @Html.DisplayFor(model => item.Capacidad)
                            </td>

                            <td>
                                $ @Html.DisplayFor(model => item.TarifaDiaOrdinario)
                            </td>

                            <td>
                                $ @Html.DisplayFor(model => item.TarifaDiaEspecial)
                            </td>

                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">
                                        Disponible
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Ocupado
                                    </span>
                                }
                            </td>

                            <td>
                                <a asp-action="Calendario"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-xs">

                                    Ver calendario
                                </a>
                            </td>

                            <td>
                                <a asp-controller="Reservas"
                                   asp-action="Create"
                                   asp-route-id="@item.Id"
                                   class="btn btn-fodun btn-xs">

                                    Reservar
                                </a>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>

                                    <div class="d-flex justify-content-center gap-2 flex-wrap">

                                        <a asp-action="Edit"
                                        asp-route-id="@item.Id"
                                        class="btn btn-primary btn-xs">

                                            Editar
                                        </a>

                                        <form asp-action="Delete"
                                           asp-route-id="@item.Id method="post" onsubmit="return confirm('¿Seguro que deseas eliminar este registro?');" style="display:inline;"
                                        class="btn btn-danger btn-xs">

                                            Eliminar
                                        </form>

                                    </div>

                                </td>
                            }
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </section>

</div>