    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="fodun-panel">

                <h2 class="fodun-section-title text-center mb-4">
                    Iniciar Sesión
                </h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form method="post">

                    <div class="mb-3">
                        <label class="form-label">
                            Documento
                        </label>

                        <input type="Documento"
                               name="Documento"
                               class="form-control" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Contraseña
                        </label>

                        <input type="password"
                               name="password"
                               class="form-control" />
                    </div>

                    <div class="d-grid">
                        <button type="submit"
                                class="btn btn-fodun">

                            Ingresar
                        </button>
                    </div>
                    <a asp-controller="Usuarios" asp-action="Create" class="btn about-team-card">
                        + Registrar usuario
                    </a>
                </form>

               
            </div>

        </div>

    </div>

</div>
