@model IEnumerable<SistemaReservas.Models.Sedes>

@{
    ViewData["Title"] = "Index";
}

<div class="container my-5">

    <section class="inventario-section">

        <!-- TITULO -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Sedes Recreativas y Apartamentos</h2>
                <p class="text-muted mb-0">
                    Seleccione una sede para visualizar los alojamientos disponibles
                </p>
            </div>
            @if (User.IsInRole("Admin"))
            {
            <a asp-action="Create" class="btn btn-fodun">
                + Nueva Sede
            </a>
            }
        </div>

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table-inventario">

                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Ubicación</th>
                        <th>Seleccionar</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @Html.DisplayFor(model => item.Nombre)
                            </td>

                            <td>
                                @Html.DisplayFor(model => item.Descripcion)
                            </td>

                            <td>
                                @switch (item.Tipo.ToString())
                                {
                                case "1":
                                <span class="badge bg-success">Sede Recreativa</span>
                                break;
                                case "2":
                                <span class="badge bg-info text-dark">Apartamento</span>
                                break;
                                default:
                                <span class="badge bg-secondary">@item.Tipo</span>
                                break;
                                }
                            </td>

                            <td>
                                @Html.DisplayFor(model => item.Ubicacion)
                            </td>

                            <td>
                                <a asp-controller="Alojamiento"
                                   asp-action="Index"
                                   asp-route-sedeId="@item.Id"
                                   class="btn btn-fodun btn-sm">

                                    Seleccionar
                                </a>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a asp-action="Edit"
                                        asp-route-id="@item.Id"
                                        class="btn btn-warning btn-xs">
                                            Editar
                                        </a>

                                        <a asp-action="Details"
                                        asp-route-id="@item.Id"
                                        class="btn btn-info btn-xs text-white">
                                            Detalles
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar este registro?');" style="display:inline;">
                                            <button type="submit" class="btn btn-danger btn-xs">
                                                Eliminar
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </section>

</div>